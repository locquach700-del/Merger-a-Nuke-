--  HỆ THỐNG KIỂM TRA TỌA ĐỘ: BẠN ĐANG ĐỨNG Ở BASE MẤY?
-- ========================================================
task.spawn(function()
    while true do
        local character = Player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        
        if hrp and BasesFolder then
            local closestBase = "Không ở trong Base nào"
            local shortestDistance = math.huge
            
            -- Quét qua cả 8 Base trên map để xem bạn đang ở gần tâm Base nào nhất
            for i = 1, 8 do
                local baseFrame = BasesFolder:FindFirstChild("Base" .. i)
                if baseFrame then
                    -- Thường Base sẽ có một Part nền chính (ví dụ "BuildArea", "Floor", "Platform" hoặc chính nó)
                    local corePart = baseFrame:FindFirstChild("BuildArea") or baseFrame:FindFirstChild("Floor") or baseFrame:FindFirstChildOfClass("Part") or baseFrame
                    if corePart and corePart:IsA("BasePart") then
                        local distance = (hrp.Position - corePart.Position).Magnitude
                        -- Nếu khoảng cách nhỏ hơn 65 studs tức là bạn đang đứng bên trong khu đất đó
                        if distance < 65 and distance < shortestDistance then
                            shortestDistance = distance
                            closestBase = tostring(i)
                        end
                    end
                end
            end
            
            -- Nếu phát hiện bạn vừa bước sang Base khác, cập nhật chữ trên UI ngay
            if CurrentStandingBase ~= closestBase then
                CurrentStandingBase = closestBase
                if closestBase ~= "Không ở trong Base nào" then
                    StandingParagraph:Set({
                        Title = "👁️ VỊ TRÍ THỰC TẾ CỦA BẠN",
                        Content = "Bạn đang đứng tại khu vực: Base Số [ " .. closestBase .. " ]"
                    })
                else
                    StandingParagraph:Set({
                        Title = "👁️ VỊ TRÍ THỰC TẾ CỦA BẠN",
                        Content = "Bạn đang đứng tại khu vực: [ Ngoài rìa / Giữa đường ]"
                    })
                end
            end
        end
        task.wait(0.5) -- Cứ mỗi 0.5 giây kiểm tra vị trí một lần cho mượt, không lo lag game
    end
end)

-- ========================================================
--  HỆ THỐNG GAMEPLAY QUÉT VÀ GỘP NUKE (GIỮ NGUYÊN)
-- ========================================================
local function getNukeData(nuke)
    local level = nil
    local targetPart = nil
    local billboard = nuke:FindFirstChildOfClass("BillboardGui") or nuke:FindFirstChild(true)
    if billboard and billboard:FindFirstChildOfClass("TextLabel") then
        level = tonumber(billboard:FindFirstChildOfClass("TextLabel").Text)
        targetPart = billboard.Parent
    end
    if not level then
        local levelObj = nuke:FindFirstChild("Level") or nuke:FindFirstChild("level")
        if levelObj and levelObj:IsA("ValueBase") then level = tonumber(levelObj.Value) end
        level = level or tonumber(nuke.Name) or 1
        targetPart = nuke:IsA("BasePart") and nuke or nuke.PrimaryPart or nuke:FindFirstChildOfClass("BasePart")
    end
    return level, targetPart
end

local function forceDropNuke()
    if DropRemote then pcall(function() DropRemote:FireServer() end) end
    local character = Player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if humanoid and hrp then
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 6, 0)
        humanoid.Jump = true
    end
    task.wait(0.2)
end

local function teleportToPart(part)
    local character = Player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp and part and part:IsA("BasePart") then
        for _, p in pairs(character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
        hrp.CFrame = part.CFrame + Vector3.new(0, 1.2, 0)
        task.wait(0.45)
    end
end

task.spawn(function()
    while true do
        if getgenv().AutoMergeActive and BasesFolder then
            local currentBase = BasesFolder:FindFirstChild("Base" .. tostring(getgenv().TargetBaseNumber))
            local nukeFolder = currentBase and (currentBase:FindFirstChild("Nukes") or currentBase:FindFirstChild("Nuke"))
            
            if nukeFolder then
                local allNukes = nukeFolder:GetChildren()
                local nukeList = {}
                for _, nuke in ipairs(allNukes) do
                    local lvl, part = getNukeData(nuke)
                    if lvl and part then table.insert(nukeList, {instance = nuke, level = lvl, part = part}) end
                end
                
                table.sort(nukeList, function(a, b) return a.level < b.level end)
                local mergedThisTick = false
                
                for i = 1, #nukeList do
                    if mergedThisTick or not getgenv().AutoMergeActive then break end
                    local nukeA = nukeList[i]
                    if nukeA.instance.Parent and nukeA.part.Parent then
                        for j = i + 1, #nukeList do
                            local nukeB = nukeList[j]
                            if nukeB.instance.Parent and nukeB.part.Parent and nukeA.level == nukeB.level then
                                teleportToPart(nukeA.part)
                                task.wait(0.2)
                                teleportToPart(nukeB.part)
                                task.wait(0.25)
                                if nukeA.instance.Parent or nukeB.instance.Parent then forceDropNuke() end
                                mergedThisTick = true
                                break
                            end
                        end
                    end
                end
                if not mergedThisTick then forceDropNuke() end
            end
        end
        task.wait(0.6)
    end
end)
